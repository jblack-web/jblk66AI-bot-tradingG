# ─────────────────────────────────────────────────────────────────────────────
# jblk66AI – Development Environment
# Copy to .env and fill in real values before running locally.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/jblk66ai-dev
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_dev
MONGO_DB=jblk66ai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=changeme_dev

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_change_me_before_production
JWT_EXPIRES_IN=7d

# ── Admin seed account ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@jblk66ai.local
ADMIN_PASSWORD=Admin@1234!Dev

# ── Bitcoin / Trading ─────────────────────────────────────────────────────────
BTC_USD_PRICE=50000

# ── SMTP (optional – leave blank to skip email sending in dev) ────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@jblk66ai.local

# ── External API keys (leave blank to use mock data in dev) ──────────────────
COINMARKETCAP_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
